       "     'text': 'Show me documentation for al_install_keyboard',\n",
       "     'user': 'UF5P58M0U',\n",
       "     'ts': '1546542631.008700'},\n",
       "    {'client_msg_id': '0377bb31-0791-4ead-b582-67d83c287764',\n",
