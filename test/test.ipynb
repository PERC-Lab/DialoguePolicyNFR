       "     'type': 'message',\n",
       "     'text': 'ssh_get_publickey example code',\n",
       "     'user': 'UC9RKA4E5',\n",
       "     'ts': '1534520086.000100'},\n",
       "    {'client_msg_id': '7ef1ca8d-c3ed-47ea-8b2a-d73010e606e3',\n",
       "     'type': 'message',\n",
       "     'text': 'There are also the functions related to \"public key\" in the ssh_session module:\\n\\nssh_get_publickey\\nssh_get_publickey_hash\\nssh_get_server_publickey',\n",
       "     'user': 'UB659D0FM',\n",
       "     'ts': '1534520065.000100'},\n",
       "    {'client_msg_id': 'b391d9c8-76b4-4a75-9138-bb39b61ee617',\n",
       "     'type': 'message',\n",
       "     'text': 'how to get ssh public key from host',\n",
       "     'user': 'UC9RKA4E5',\n",
       "     'ts': '1534520046.000100'},\n",
       "    {'client_msg_id': '37b1b594-7050-44e8-b1d7-024496f7bbf6',\n",
       "     'type': 'message',\n",
       "     'text': 'There are 21 public key functions:\\n\\nssh_key_clean\\nssh_key_cmp\\nssh_key_free\\nssh_key_is_private\\nssh_key_is_public\\nssh_key_new\\nssh_key_type\\nssh_key_type_from_name\\nssh_key_type_to_char\\nssh_pki_copy_cert_to_privkey\\nssh_pki_export_privkey_file\\nssh_pki_export_privkey_to_pubkey\\nssh_pki_export_pubkey_base64\\nssh_pki_generate\\nssh_pki_import_cert_base64\\nssh_pki_import_cert_file\\nssh_pki_import_privkey_base64\\nssh_pki_import_privkey_file\\nssh_pki_import_pubkey_base64\\nssh_pki_import_pubkey_file\\nssh_pki_key_ecdsa_name',\n",
       "     'user': 'UB659D0FM',\n",
       "     'ts': '1534519997.000100'},\n",
