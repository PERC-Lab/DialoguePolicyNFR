       "    {'client_msg_id': 'f340e2c0-a74a-45de-916d-4f0922b6a5ff',\n",
       "     'type': 'message',\n",
       "     'text': 'typedef struct ALLEGRO_KEYBOARD_EVENT\\n{\\n   _AL_EVENT_HEADER(struct ALLEGRO_KEYBOARD)\\n   struct ALLEGRO_DISPLAY *display; /* the window the key was pressed in */\\n   int keycode;                 /* the physical key pressed */\\n   int unichar;                 /* unicode character or negative */\\n   unsigned int modifiers;      /* bitfield */\\n   bool repeat;                 /* auto-repeated or not */\\n} ALLEGRO_KEYBOARD_EVENT;',\n",
       "     'user': 'UB659D0FM',\n",
       "     'ts': '1552252301.004400'},\n",
       "    {'client_msg_id': 'b5339a95-8ccb-42cd-97ef-428164ab9e19',\n",
       "     'type': 'message',\n",
       "     'text': 'Can I see the definition?',\n",
       "     'user': 'UGTTQM082',\n",
       "     'ts': '1552252292.004200'},\n",
       "    {'client_msg_id': '6b92efc4-f26e-41d9-8614-1ff024fe171a',\n",
       "     'type': 'message',\n",
       "     'text': 'Sure! ALLEGRO_KEYBOARD_EVENT is a struct that contains a display pointer, the keycode of the physical key pressed, and other information',\n",
       "     'user': 'UB659D0FM',\n",
       "     'ts': '1552252267.003800'},\n",
       "    {'client_msg_id': '0c232dae-d1c1-4e17-b4c8-e0e5c0e938a9',\n",
       "     'type': 'message',\n",
       "     'text': 'Can I have more information about the ALLEGRO_KEYBOARD_EVENT object?',\n",
       "     'user': 'UGTTQM082',\n",
       "     'ts': '1552252211.003600'},\n",
       "    {'client_msg_id': 'f2152481-b5f2-4de9-839c-50d108873bc6',\n",
       "     'type': 'message',\n",
       "     'text': \"union ALLEGRO_EVENT\\n{\\n   /* This must be the same as the first field of _AL_EVENT_HEADER.  */\\n   ALLEGRO_EVENT_TYPE type;\\n   /* `any' is to allow the user to access the other fields which are\\n    * common to all event types, without using some specific type\\n    * structure.\\n    */\\n   ALLEGRO_ANY_EVENT      any;\\n   ALLEGRO_DISPLAY_EVENT  display;\\n   ALLEGRO_JOYSTICK_EVENT joystick;\\n   ALLEGRO_KEYBOARD_EVENT keyboard;\\n   ALLEGRO_MOUSE_EVENT    mouse;\\n   ALLEGRO_TIMER_EVENT    timer;\\n   ALLEGRO_TOUCH_EVENT    touch;\\n   ALLEGRO_USER_EVENT     user;\\n};\",\n",
       "     'user': 'UB659D0FM',\n",
       "     'ts': '1552252190.003200'},\n",
       "    {'client_msg_id': '778764bf-08df-44bb-a447-b20ae3b6e628',\n",
       "     'type': 'message',\n",
