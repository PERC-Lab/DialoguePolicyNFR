       "     'type': 'message',\n",
       "     'text': 'Sample and stream playback mode. ALLEGRO_PLAYMODE_ONCE, ALLEGRO_PLAYMODE_LOOP, ALLEGRO_PLAYMODE_BIDIR',\n",
       "     'user': 'UB659D0FM',\n",
