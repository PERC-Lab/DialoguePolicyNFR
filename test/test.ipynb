       "     'ts': '1539899061.000100'},\n",
       "    {'client_msg_id': '21c0c304-4b1f-4981-ab24-861bd1ee1bd3',\n",
       "     'type': 'message',\n",
       "     'text': 'How do I register for KEY_DOWN events',\n",
