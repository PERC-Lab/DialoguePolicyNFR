       "     'ts': '1534515580.000100'},\n",
       "    {'client_msg_id': '33577cd2-344c-4bac-9914-2110f3319c99',\n",
       "     'type': 'message',\n",
       "     'text': 'Hello! I have several functions relating to ssh_session. What can I help you with?',\n",
       "     'user': 'UB659D0FM',\n",
       "     'ts': '1534515550.000300'},\n",
