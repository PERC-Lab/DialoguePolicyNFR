       " 29: {'library': 'libssh',\n",
       "  'metadata': {'wizard': '03', 'programmer': '29'},\n",
       "  'score': {0: 2,\n",
       "   1: 1,\n",
       "   2: 1,\n",
       "   3: 1,\n",
       "   4: 0,\n",
       "   5: 0,\n",
       "   6: 0,\n",
